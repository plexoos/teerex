{
  "name": "teerex",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },
  "runArgs": [
    "--shm-size=10.24gb"
  ],
  "remoteEnv": {
    "CODEX_HOME": "${containerWorkspaceFolder}/.codex"
  },
  "mounts": [
    "source=${localEnv:HOME}/.codex,target=/root/.codex,type=bind"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "openai.chatgpt",
        "ms-python.python",
        "ms-toolsai.jupyter"
      ]
    }
  }
}
